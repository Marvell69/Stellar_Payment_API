# Dependencies (re-installed inside Docker)
node_modules

# Environment files – never bake secrets into images
.env
.env.*
!.env.example

# Version control
.git
.gitignore

# Editors / OS noise
.vscode
.idea
*.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Test & coverage output
coverage
*.test.js
*.spec.js

# CI / tooling configs not needed at runtime
.github
